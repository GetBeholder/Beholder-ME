{
  "_comment": "SHARED parity fixture for the canonical state-apply semantics. Both DataGen's shared/apply_state.py (tests/parity/test_apply_delta.py) and the extension's state.js applyDelta (test/apply_delta_parity.test.js) are asserted against these. Each case: prev (state) + delta (v2 wrapper or bare) -> expected (state after). If you change apply semantics in EITHER repo, update this and both tests.",
  "cases": [
    {"name": "species redundant-human stripped (prev absent)",
     "prev": {}, "delta": {"changed": true, "delta": {"Tim": {"species": "human"}}}, "expected": {}},
    {"name": "species redundant-human stripped, other state survives",
     "prev": {"Tim": {"body": {"chest": {"worn": [{"item": "shirt", "damage": "pristine"}]}}}},
     "delta": {"changed": true, "delta": {"Tim": {"species": "human"}}},
     "expected": {"Tim": {"body": {"chest": {"worn": [{"item": "shirt", "damage": "pristine"}]}}}}},
    {"name": "species reveal kept (non-human -> human)",
     "prev": {"Tim": {"species": "anomaly"}}, "delta": {"changed": true, "delta": {"Tim": {"species": "human"}}},
     "expected": {"Tim": {"species": "human"}}},
    {"name": "species real non-human set",
     "prev": {}, "delta": {"changed": true, "delta": {"Mara": {"species": "lamia"}}},
     "expected": {"Mara": {"species": "lamia"}}},
    {"name": "worn add to empty slot",
     "prev": {"Tim": {"body": {}}}, "delta": {"changed": true, "delta": {"Tim": {"body": {"chest": {"worn": [{"item": "tunic", "damage": "pristine"}]}}}}},
     "expected": {"Tim": {"body": {"chest": {"worn": [{"item": "tunic", "damage": "pristine"}]}}}}},
    {"name": "worn clear [] cascades to empty -> drop everything",
     "prev": {"Tim": {"body": {"chest": {"worn": [{"item": "tunic", "damage": "pristine"}]}}}},
     "delta": {"changed": true, "delta": {"Tim": {"body": {"chest": {"worn": []}}}}}, "expected": {}},
    {"name": "holding clear {} drops",
     "prev": {"Tim": {"body": {"right_hand": {"holding": {"item": "sword", "damage": "pristine"}}}}},
     "delta": {"changed": true, "delta": {"Tim": {"body": {"right_hand": {"holding": {}}}}}}, "expected": {}},
    {"name": "holding clear empty-string (legacy v0.2) drops",
     "prev": {"Tim": {"body": {"right_hand": {"holding": "sword"}}}},
     "delta": {"changed": true, "delta": {"Tim": {"body": {"right_hand": {"holding": ""}}}}}, "expected": {}},
    {"name": "holding replace",
     "prev": {"Tim": {"body": {"right_hand": {"holding": {"item": "sword", "damage": "pristine"}}}}},
     "delta": {"changed": true, "delta": {"Tim": {"body": {"right_hand": {"holding": {"item": "shield", "damage": "cracked"}}}}}},
     "expected": {"Tim": {"body": {"right_hand": {"holding": {"item": "shield", "damage": "cracked"}}}}}},
    {"name": "bare:true added",
     "prev": {"Tim": {"body": {}}}, "delta": {"changed": true, "delta": {"Tim": {"body": {"chest": {"bare": true}}}}},
     "expected": {"Tim": {"body": {"chest": {"bare": true}}}}},
    {"name": "missing:true added",
     "prev": {"Tim": {"body": {}}}, "delta": {"changed": true, "delta": {"Tim": {"body": {"left_hand": {"missing": true}}}}},
     "expected": {"Tim": {"body": {"left_hand": {"missing": true}}}}},
    {"name": "multi-character delta (carve-out + real species together)",
     "prev": {"Tim": {"body": {}}, "Mara": {"body": {}}},
     "delta": {"changed": true, "delta": {"Tim": {"body": {"chest": {"worn": [{"item": "coat", "damage": "pristine"}]}}}, "Mara": {"species": "lamia"}}},
     "expected": {"Tim": {"body": {"chest": {"worn": [{"item": "coat", "damage": "pristine"}]}}}, "Mara": {"body": {}, "species": "lamia"}}},
    {"name": "v2 changed:false is a no-op",
     "prev": {"Tim": {"species": "lamia"}}, "delta": {"changed": false}, "expected": {"Tim": {"species": "lamia"}}},
    {"name": "bare delta (no v2 wrapper) applies",
     "prev": {}, "delta": {"Tim": {"body": {"chest": {"worn": [{"item": "hat", "damage": "pristine"}]}}}},
     "expected": {"Tim": {"body": {"chest": {"worn": [{"item": "hat", "damage": "pristine"}]}}}}},
    {"name": "partial clear: body drops, sibling top-level field survives",
     "prev": {"Tim": {"body": {"chest": {"worn": [{"item": "tunic", "damage": "pristine"}]}}, "species": "lamia"}},
     "delta": {"changed": true, "delta": {"Tim": {"body": {"chest": {"worn": []}}}}},
     "expected": {"Tim": {"species": "lamia"}}},

    {"name": "worn merge: ADD a garment, keep co-located ones (bra/blouse/blazer)",
     "prev": {"Eva": {"body": {"chest": {"worn": [{"item": "blouse", "damage": "pristine", "color": "white"}, {"item": "blazer", "damage": "pristine", "color": "navy"}]}}}},
     "delta": {"changed": true, "delta": {"Eva": {"body": {"chest": {"worn": [{"item": "bra", "damage": "pristine"}]}}}}},
     "expected": {"Eva": {"body": {"chest": {"worn": [{"item": "blouse", "damage": "pristine", "color": "white"}, {"item": "blazer", "damage": "pristine", "color": "navy"}, {"item": "bra", "damage": "pristine"}]}}}}},
    {"name": "worn merge: UPDATE in place, keep unre-emitted color (blazer damaged keeps navy)",
     "prev": {"Eva": {"body": {"back": {"worn": [{"item": "blouse", "damage": "pristine", "color": "white"}, {"item": "blazer", "damage": "pristine", "color": "navy"}]}}}},
     "delta": {"changed": true, "delta": {"Eva": {"body": {"back": {"worn": [{"item": "blazer", "damage": "damaged"}]}}}}},
     "expected": {"Eva": {"body": {"back": {"worn": [{"item": "blouse", "damage": "pristine", "color": "white"}, {"item": "blazer", "damage": "damaged", "color": "navy"}]}}}}},
    {"name": "worn merge: identity match is case-insensitive, no duplicate",
     "prev": {"Eva": {"body": {"chest": {"worn": [{"item": "Coat", "damage": "pristine", "color": "grey"}]}}}},
     "delta": {"changed": true, "delta": {"Eva": {"body": {"chest": {"worn": [{"item": "coat", "damage": "torn"}]}}}}},
     "expected": {"Eva": {"body": {"chest": {"worn": [{"item": "Coat", "damage": "torn", "color": "grey"}]}}}}},
    {"name": "worn_remove: subtract the named garment, keep others",
     "prev": {"Eva": {"body": {"chest": {"worn": [{"item": "blouse", "damage": "pristine", "color": "white"}, {"item": "blazer", "damage": "pristine", "color": "navy"}]}}}},
     "delta": {"changed": true, "delta": {"Eva": {"body": {"chest": {"worn_remove": ["blazer"]}}}}},
     "expected": {"Eva": {"body": {"chest": {"worn": [{"item": "blouse", "damage": "pristine", "color": "white"}]}}}}},
    {"name": "worn_remove: last garment clears the slot (case-insensitive, cascade)",
     "prev": {"Eva": {"body": {"chest": {"worn": [{"item": "blazer", "damage": "pristine"}]}}}},
     "delta": {"changed": true, "delta": {"Eva": {"body": {"chest": {"worn_remove": ["Blazer"]}}}}},
     "expected": {}},
    {"name": "worn + worn_remove in one delta: remove wins for the same name, adds apply",
     "prev": {"Eva": {"body": {"chest": {"worn": [{"item": "blazer", "damage": "pristine", "color": "navy"}]}}}},
     "delta": {"changed": true, "delta": {"Eva": {"body": {"chest": {"worn": [{"item": "bra", "damage": "pristine"}], "worn_remove": ["blazer"]}}}}},
     "expected": {"Eva": {"body": {"chest": {"worn": [{"item": "bra", "damage": "pristine"}]}}}}},
    {"name": "worn_remove of an absent garment is a no-op (does not create the slot)",
     "prev": {"Eva": {"body": {"chest": {"worn": [{"item": "shirt", "damage": "pristine"}]}}}},
     "delta": {"changed": true, "delta": {"Eva": {"body": {"waist": {"worn_remove": ["belt"]}}}}},
     "expected": {"Eva": {"body": {"chest": {"worn": [{"item": "shirt", "damage": "pristine"}]}}}}},
    {"name": "species G1 redundant gender-noun does not clobber non-human prev (woman/kitsune)",
     "prev": {"Tim": {"species": "kitsune"}}, "delta": {"changed": true, "delta": {"Tim": {"species": "woman"}}}, "expected": {"Tim": {"species": "kitsune"}}},
    {"name": "species G1 redundant gender-noun does not clobber non-human prev (lady/kitsune)",
     "prev": {"Tim": {"species": "kitsune"}}, "delta": {"changed": true, "delta": {"Tim": {"species": "lady"}}}, "expected": {"Tim": {"species": "kitsune"}}},
    {"name": "species G1 reveal still works (lamia -> human)",
     "prev": {"Mara": {"species": "lamia"}}, "delta": {"changed": true, "delta": {"Mara": {"species": "human"}}}, "expected": {"Mara": {"species": "human"}}},
    {"name": "species G1 redundant gender-noun strips when prev absent (boy -> human default)",
     "prev": {}, "delta": {"changed": true, "delta": {"Kip": {"species": "boy"}}}, "expected": {}},
    {"name": "species G1 redundant strips but other delta state still applies (girl over kitsune + coat)",
     "prev": {"Ana": {"species": "kitsune"}}, "delta": {"changed": true, "delta": {"Ana": {"species": "girl", "body": {"chest": {"worn": [{"item": "coat", "damage": "pristine"}]}}}}}, "expected": {"Ana": {"species": "kitsune", "body": {"chest": {"worn": [{"item": "coat", "damage": "pristine"}]}}}}},
    {"name": "canon: boot+boots fold to one, first-seen surface preserved (boot)",
     "prev": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boot"}]}}}}, "delta": {"changed": true, "delta": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boots", "color": "black"}]}}}}}, "expected": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boot", "color": "black"}]}}}}},
    {"name": "canon: reverse boots+boot fold to one, first-seen surface (boots)",
     "prev": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boots"}]}}}}, "delta": {"changed": true, "delta": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boot", "color": "black"}]}}}}}, "expected": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boots", "color": "black"}]}}}}},
    {"name": "canon NEG: distinct lexeme boot+sandal stay two",
     "prev": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boot"}]}}}}, "delta": {"changed": true, "delta": {"Sh": {"body": {"left_foot": {"worn": [{"item": "sandal"}]}}}}}, "expected": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boot"}, {"item": "sandal"}]}}}}},
    {"name": "canon NEG: suspender/suspenders differ in footprint, stay two",
     "prev": {"Sh": {"body": {"left_shoulder": {"worn": [{"item": "suspender"}]}}}}, "delta": {"changed": true, "delta": {"Sh": {"body": {"left_shoulder": {"worn": [{"item": "suspenders"}]}}}}}, "expected": {"Sh": {"body": {"left_shoulder": {"worn": [{"item": "suspender"}, {"item": "suspenders"}]}}}}},
    {"name": "canon NEG STOP: sock/socks stay two (self-layering)",
     "prev": {"Sh": {"body": {"left_foot": {"worn": [{"item": "sock", "color": "white"}]}}}}, "delta": {"changed": true, "delta": {"Sh": {"body": {"left_foot": {"worn": [{"item": "socks", "color": "black"}]}}}}}, "expected": {"Sh": {"body": {"left_foot": {"worn": [{"item": "sock", "color": "white"}, {"item": "socks", "color": "black"}]}}}}},
    {"name": "canon: worn_remove [boots] clears a stored boot",
     "prev": {"Sh": {"body": {"left_foot": {"worn": [{"item": "boot"}]}}}}, "delta": {"changed": true, "delta": {"Sh": {"body": {"left_foot": {"worn_remove": ["boots"]}}}}}, "expected": {}},
    {"name": "canon: trouser+trousers fold to one",
     "prev": {"Sh": {"body": {"waist": {"worn": [{"item": "trouser"}]}}}}, "delta": {"changed": true, "delta": {"Sh": {"body": {"waist": {"worn": [{"item": "trousers", "color": "grey"}]}}}}}, "expected": {"Sh": {"body": {"waist": {"worn": [{"item": "trouser", "color": "grey"}]}}}}},
    {"name": "wounds merge: two distinct same-slot wounds ACCUMULATE (was REPLACE; pairs Beholder-ST ea62b04)",
     "prev": {"Kael": {"body": {"head": {"wounds": [{"text": "fractured skull", "severity": "critical", "bleeding": false}]}}}}, "delta": {"changed": true, "delta": {"Kael": {"body": {"head": {"wounds": [{"text": "broken nose", "severity": "serious", "bleeding": true}]}}}}}, "expected": {"Kael": {"body": {"head": {"wounds": [{"text": "fractured skull", "severity": "critical", "bleeding": false}, {"text": "broken nose", "severity": "serious", "bleeding": true}]}}}}},
    {"name": "wounds merge: same-text UPDATES in place (severity/bleeding win, first-seen surface kept)",
     "prev": {"Kael": {"body": {"left_arm": {"wounds": [{"text": "gash", "severity": "minor", "bleeding": false}]}}}}, "delta": {"changed": true, "delta": {"Kael": {"body": {"left_arm": {"wounds": [{"text": "Gash", "severity": "serious", "bleeding": true}]}}}}}, "expected": {"Kael": {"body": {"left_arm": {"wounds": [{"text": "gash", "severity": "serious", "bleeding": true}]}}}}},
    {"name": "wounds: [] clears the slot's wounds; co-located worn survives",
     "prev": {"Dani": {"body": {"head": {"wounds": [{"text": "concussion", "severity": "serious"}], "worn": [{"item": "helmet", "damage": "pristine"}]}}}}, "delta": {"changed": true, "delta": {"Dani": {"body": {"head": {"wounds": []}}}}}, "expected": {"Dani": {"body": {"head": {"worn": [{"item": "helmet", "damage": "pristine"}]}}}}}
  ]
}
